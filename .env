# ─────────────────────────────────────────────
# Cómo usar este archivo:
#   cp .env.example .env
# Luego editas lo necesario (sobre todo contraseñas)
# Ojo: NO subir el .env al repo
# ─────────────────────────────────────────────

# ─────── PostgreSQL ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=DevSecure_2026!
POSTGRES_DB=TesloDB
POSTGRES_PUBLISH_PORT=5432
POSTGRES_CONTAINER_NAME=teslo-db

# ─────── Backend (NestJS) ─────────────────────
# Estos valores deben coincidir con los de arriba
APP_VERSION=1.0.1
STAGE=dev
DB_HOST=db               # nombre del servicio en docker-compose
DB_PORT=5432
DB_USERNAME=postgres     # mismo usuario de Postgres
DB_PASSWORD=DevSecure_2026!   # misma contraseña
DB_NAME=TesloDB          # misma base de datos
PORT=3000
BACKEND_PUBLISH_PORT=3000
BACKEND_CONTAINER_NAME=teslo-backend
HOST_API=http://localhost:3000/api
JWT_SECRET=8f3a9c1e7b2d4f6a9e0c3b5d1a7f8c2e4b6d9f1a0c3e5b7d2f8a6c1e9b3d7f

# ─────── Frontend (Nginx) ─────────────────────
FRONTEND_PUBLISH_PORT=80
FRONTEND_CONTAINER_NAME=teslo-frontend